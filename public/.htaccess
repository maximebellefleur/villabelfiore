Options -Indexes

# Increase upload and post size limits for photo uploads
LimitRequestBody 52428800
<IfModule mod_php.c>
  php_value upload_max_filesize 25M
  php_value post_max_size 30M
  php_value memory_limit 128M
  php_value max_execution_time 120
</IfModule>
<IfModule mod_php8.c>
  php_value upload_max_filesize 25M
  php_value post_max_size 30M
  php_value memory_limit 128M
  php_value max_execution_time 120
</IfModule>

RewriteEngine On

# Required for subdirectory installs (e.g. example.com/rooted/)
# Apache needs this to resolve rewrites relative to the subfolder
RewriteBase /rooted/

# Always route manifest.json through PHP so APP_BASE paths are correct
RewriteRule ^manifest\.json$ index.php [L,QSA]

# Serve existing files and directories directly (assets, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route all other requests through index.php
RewriteRule ^ index.php [L]

# Deny access to sensitive files
<FilesMatch "\.(env|log|sql|sh|bak|md|user\.ini)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Browser caching for static assets
# CSS/JS use ?v=timestamp cache-busting, so 1-year cache is safe
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType text/javascript           "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/gif                 "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
